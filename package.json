{
  "name": "iisl",
  "version": "0.1.0",
  "private": true,
  "description": "Issue Resolution Integrity Layer — Phase 1 Pilot",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "demo:start":  "node scripts/demo-start-bootstrap.js",
    "demo:start:internal": "ts-node -P tsconfig.base.json scripts/demo-start.ts",
    "demo:reset":  "ts-node -P tsconfig.base.json scripts/demo-reset.ts",
    "demo:smoke":  "ts-node -P tsconfig.base.json scripts/demo-smoke.ts",
    "doctor":      "ts-node -P tsconfig.base.json scripts/doctor.ts",
    "build:workspace-libs": "npm run build --workspace=packages/shared && npm run build --workspace=packages/policy",
    "dev":         "npm run build:workspace-libs && concurrently --names api,worker,sidebar --prefix-colors cyan,yellow,green \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/worker\" \"npm run dev --workspace=apps/sidebar\"",
    "db:migrate":  "ts-node -P tsconfig.base.json scripts/migrate.ts",
    "db:seed":     "ts-node -P tsconfig.base.json scripts/seed.ts",
    "db:reset":    "ts-node -P tsconfig.base.json scripts/migrate.ts --reset",
    "infra:up":    "docker compose -f infra/docker-compose.yml up -d",
    "infra:down":  "docker compose -f infra/docker-compose.yml down",
    "infra:logs":  "docker compose -f infra/docker-compose.yml logs -f",
    "build":       "npm run build --workspaces --if-present",
    "test":        "vitest run",
    "test:watch":  "vitest",
    "typecheck":   "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.0",
    "pg": "^8.11.0",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
