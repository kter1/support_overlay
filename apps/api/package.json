{
  "name": "@iisl/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --project tsconfig.json src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "node -r ts-node/register src/db/migrate.ts",
    "seed": "node -r ts-node/register src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@iisl/shared": "*",
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.4",
    "pino": "^8.18.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
