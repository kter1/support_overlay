# ============================================================================
# IISL Phase 1 — Environment Variables
# ============================================================================
# Copy to repo root before first run:
#   cp infra/.env.example .env
#
# All values here are the LOCAL DEMO DEFAULTS.
# They must be consistent with docker-compose.yml defaults.
#
# CREDENTIAL CONSISTENCY RULE:
#   DATABASE_URL user/password/dbname must match POSTGRES_USER/PASSWORD/DB.
#   The demo:start and doctor scripts enforce this and will fail fast if they
#   diverge. If you change one, change all four.
#
# DO NOT use these values in production. Replace all secrets before deploy.
# ============================================================================

# ─── Database (REQUIRED) ─────────────────────────────────────────────────────
# Full Postgres connection URL. Must match the POSTGRES_* vars below exactly.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://iisl:iisl_dev@127.0.0.1:5432/iisl

# Postgres credentials — must match DATABASE_URL and docker-compose.yml defaults.
# Changing any of these requires: npm run demo:reset (to recreate the DB user).
POSTGRES_USER=iisl
POSTGRES_PASSWORD=iisl_dev
POSTGRES_DB=iisl

# Postgres port override. Default: 5432. Change if 5432 is occupied on your machine.
# If changed: update DATABASE_URL port to match.
# POSTGRES_PORT=5432

# ─── API Server (REQUIRED) ───────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# ─── Auth Tokens (REQUIRED) ──────────────────────────────────────────────────
# Replace with real secrets for production.
OPERATOR_TOKEN=operator-token-dev
AGENT_TOKEN=agent-token-dev

# ─── Worker (REQUIRED) ───────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_MS=2000
WORKER_MAX_ATTEMPTS=5

# ─── Connector: Zendesk ──────────────────────────────────────────────────────
# Leave ZENDESK_API_TOKEN empty to use the fixture simulator.
ZENDESK_SUBDOMAIN=demo
ZENDESK_API_TOKEN=
ZENDESK_WEBHOOK_SECRET=demo-webhook-secret
USE_ZENDESK_SIMULATOR=true

# ─── Connector: Stripe ───────────────────────────────────────────────────────
# Leave STRIPE_API_KEY empty to use the fixture simulator.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=demo-stripe-secret
USE_STRIPE_SIMULATOR=true

# ─── Connector: Shopify ──────────────────────────────────────────────────────
# Leave SHOPIFY_ACCESS_TOKEN empty to use the fixture simulator.
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=demo-shopify-secret
USE_SHOPIFY_SIMULATOR=true

# ─── Sidebar (REQUIRED) ──────────────────────────────────────────────────────
# Must match API_PORT above.
VITE_API_BASE_URL=http://localhost:3001
SIDEBAR_PORT=5173

# ─── Observability (OPTIONAL) ────────────────────────────────────────────────
# Options: error | warn | info | debug
LOG_LEVEL=info
